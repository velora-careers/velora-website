# Public site URL — used for canonical URLs, sitemap, OpenGraph, and robots.
# Set this to your production domain in Vercel (Project → Settings → Environment Variables).
NEXT_PUBLIC_SITE_URL=https://veloracareers.com

# ---------------------------------------------------------------------------
# Contact form delivery (all optional).
# With none of these set, submissions are validated and logged server-side,
# and the form still shows the success state.
# ---------------------------------------------------------------------------

# Option A — send an email via Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=hello@veloracareers.com
# CONTACT_FROM_EMAIL=Velora Careers <noreply@veloracareers.com>

# Option B — forward the raw JSON payload to a webhook (Zapier, Make, Slack, etc.)
# CONTACT_WEBHOOK_URL=https://hooks.example.com/velora-contact
