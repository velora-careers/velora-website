# Public site URL — used for canonical URLs, sitemap, OpenGraph, and robots.
# Leave UNSET on Vercel: the app falls back to VERCEL_PROJECT_PRODUCTION_URL,
# so links/OG images resolve to whatever domain is actually serving the site
# (the *.vercel.app URL now, your custom domain automatically once you add one).
# Only set this to force a specific domain you control.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Contact form email (Gmail / Google Workspace SMTP via nodemailer).
# Set SMTP_USER + SMTP_PASS to enable the thank-you email to the candidate
# and the notification to the team. Without them, submissions are validated
# and logged server-side and the form still shows the success state.
# SMTP_PASS is a Google "App Password" (Account → Security → App passwords).
# ---------------------------------------------------------------------------
# SMTP_USER=info@veloracareers.com
# SMTP_PASS=your-16-char-app-password
# CONTACT_TO_EMAIL=info@veloracareers.com   # where team notifications go (defaults to SMTP_USER)
# SMTP_HOST=smtp.gmail.com                  # optional (default)
# SMTP_PORT=465                             # optional (default; 587 also works)
